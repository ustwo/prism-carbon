{
  "name": "prism-carbon-tracker",
  "displayName": "Prism Carbon Tracker",
  "publisher": "ustwo",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ustwo/prism-carbon.git"
  },
  "description": "PRISM is a VS Code extension that estimates the carbon footprint of AI interactions in your IDE. It captures token usage from GitHub Copilot Chat, Claude Code, and runtime LLM API calls, then estimates CO₂ equivalents and surfaces them in the sidebar, status bar, and a live dashboard.",
  "version": "1.0.1",
  "release": {
    "branches": [
      "main",
      {
        "name": "dev"
      },
      {
        "name": "ReleaseYMLFix",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "npx @vscode/vsce package --out extension.vsix"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "PRISM.vsix",
              "label": "PRISM VSIX"
            }
          ]
        }
      ]
    ]
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ecode.resetStore",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "keybindings": [],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-view-container",
          "title": "PRISM Carbon Tracker",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "my-view-container": [
        {
          "id": "myPrimaryView",
          "name": "Carbon Estimates",
          "icon": "$(eye)"
        }
      ],
      "explorer": [
        {
          "id": "ecode.budgetMiniView",
          "type": "webview",
          "name": "Budget Overview"
        }
      ]
    },
    "commands": [
      {
        "command": "ecode.openDashboard",
        "title": "PRISM: Open Carbon Dashboard",
        "icon": "$(graph)"
      },
      {
        "command": "ecode.clearStore",
        "title": "PRISM: Reset budget window"
      },
      {
        "command": "ecode.inputdisplay",
        "title": "PRISM: Input Display"
      },
      {
        "command": "ecode.purgeStore",
        "title": "PRISM: Purge all stored logs",
        "icon": "$(trash)"
      },
      {
        "command": "ecode.deleteCall",
        "title": "Delete log entry",
        "icon": "$(trash)"
      },
      {
        "command": "ecode.copyCall",
        "title": "Copy log entry",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "ecode.copyCall",
          "when": "view == myPrimaryView && viewItem == callEntry",
          "group": "inline@1"
        },
        {
          "command": "ecode.deleteCall",
          "when": "view == myPrimaryView && viewItem == callEntry",
          "group": "inline@2"
        },
        {
          "command": "ecode.copyCall",
          "when": "view == myPrimaryView && viewItem == callEntry",
          "group": "9_copy"
        },
        {
          "command": "ecode.deleteCall",
          "when": "view == myPrimaryView && viewItem == callEntry",
          "group": "9_delete"
        }
      ],
      "view/title": [
        {
          "command": "ecode.openDashboard",
          "when": "view == myPrimaryView",
          "group": "navigation@1"
        },
        {
          "command": "ecode.purgeStore",
          "when": "view == myPrimaryView",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "PRISM Carbon Tracker",
      "properties": {
        "estimatingCarbon.logRefreshIntervalSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "markdownDescription": "How often (in seconds) to poll the Copilot Chat log file for new AI interactions. Set to `0` to disable — logs will still refresh on every file save.\n\n| Interval | Impact |\n|---|---|\n| 1–10s | High CPU — only for active development |\n| 15s | Recommended — balanced |\n| 30–60s | Low CPU — suits background use |\n| 0 | Disabled — refreshes on file save only |"
        },
        "estimatingCarbon.colorNeutral": {
          "type": "string",
          "default": "#888888",
          "description": "Colour shown for calls recorded before 10 logs exist (not enough data for percentile classification). Hex format, e.g. #888888."
        },
        "estimatingCarbon.colorGreen": {
          "type": "string",
          "default": "#89d185",
          "description": "Colour for low-impact calls (below the 50th percentile of all recorded calls). Hex format, e.g. #89d185."
        },
        "estimatingCarbon.colorAmber": {
          "type": "string",
          "default": "#e2c08d",
          "description": "Colour for medium-impact calls (between the 50th and 90th percentile). Hex format, e.g. #e2c08d."
        },
        "estimatingCarbon.colorRed": {
          "type": "string",
          "default": "#f14c4c",
          "description": "Colour for high-impact calls (above the 90th percentile). Hex format, e.g. #f14c4c."
        },
        "estimatingCarbon.colorMinLogs": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "Minimum number of recorded calls required before percentile colour classification activates. Below this count all calls are shown in the neutral colour."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run typecheck && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run typecheck && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test --coverage --coverage-reporter lcov --coverage-reporter html --coverage-reporter text",
    "release": "npx @vscode/vsce package --no-dependencies --out \"distExtension/PRISM-CARBON-TRACKER.vsix\"",
    "publish": "npx @vscode/vsce publish --no-dependencies",
    "setup": "npm install && npm run compile"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/http-proxy": "^1.17.17",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "npm-run-all": "^4.1.5",
    "nyc": "^18.0.0",
    "semantic-release": "^25.0.3",
    "sinon": "^21.0.1",
    "typescript": "^5.9.3",
    "vscode": "^1.1.34"
  },
  "dependencies": {
    "@lenml/tokenizer-gemini": "^3.7.2",
    "@vscode/codicons": "^0.0.44",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "axios": "^1.13.5",
    "chart.js": "^4.5.1",
    "http-proxy": "^1.18.1",
    "mocha": "^11.7.5",
    "mockttp": "^4.2.1",
    "styled-components": "^6.4.1",
    "tiktoken": "^1.0.22",
    "vsce": "^2.15.0"
  }
}
