{
  "name": "ecode",
  "displayName": "EstimatingCarbon",
  "publisher": "development",
  "repository": {
    "type": "git",
    "url": "https://github.com/spe-uob/2025-EstimatingCarbon.git"
  },
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ecode.resetStore",
    "onCommand:ecode.inputdisplay",
    "onCommand:ecode.setApiKey",
    "onCommand:ecode.openDashboard",
    "onCommand:ecode.refreshLogs",
    "onView:myPrimaryView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "keybindings": [

    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-view-container",
          "title": "Estimating Carbon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "my-view-container": [
        {
          "id": "myPrimaryView",
          "name": "Carbon Estimates",
          "icon": "$(eye)"
        }
      ]
    },
    "commands": [
      {
        "command": "ecode.openDashboard",
        "title": "Open Carbon Dashboard"
      },
      {
        "command": "ecode.testInput",
        "title": "test input"
      },
      {
        "command": "ecode.clearStore",
        "title": "Clear stored calls"
      },
      {
        "command": "ecode.inputdisplay",
        "title": "Input Display"
      },

      {
        "command": "ecode.newFile",
        "title": "Open New File"
      },

      {
        "command": "ecode.setApiKey",
        "title": "Set Api Key"
      },
      {
        "command": "ecode.refreshLogs",
        "title": "Refresh carbon data",
        "category": "Logging"
      },
      {
        "command": "ecode.interceptorStart",
        "title": "Start Proxy Interceptor",
        "category": "Interceptor"
      },
      {
        "command": "ecode.interceptorStop",
        "title": "Stop Proxy Interceptor",
        "category": "Interceptor"
      },
      {
        "command": "ecode.interceptorOpenTerminal",
        "title": "Open Runtime Terminal",
        "category": "Interceptor"
      },
      {
        "command": "ecode.runtimeAnalysis",
        "title": "Ecode: Analyse Runtime",
        "category": "Interceptor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "release": "vsce package"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.17",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "npm-run-all": "^4.1.5",
    "sinon": "^21.0.1",
    "typescript": "^5.9.3",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44",
    "axios": "^1.13.5",
    "http-proxy": "^1.18.1",
    "mocha": "^11.7.5",
    "mockttp": "^4.2.1",
    "tiktoken": "^1.0.22"
  }
}