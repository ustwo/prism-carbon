{
  "name": "vsCodeExt",
  "displayName": "EstimatingCarbon",
  "description": "A simple ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vsCodeExt.helloWorld",
    "onCommand:vsCodeExt.inputdisplay",
    "onView:myPrimaryView"
  ],
  "main": "./dist/extension.js",
  "contributes": {

    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-view-container",
          "title": "Estimating Carbon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": { 
      "my-view-container": [
        {
          "id": "myPrimaryView",
          "name": "Carbon Estimates"
        }
      ]
    },
    "commands": [
      {
        "command": "vsCodeExt.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "vsCodeExt.inputdisplay",
        "title": "Input Display"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.11",
    "eslint": "^9.36.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
