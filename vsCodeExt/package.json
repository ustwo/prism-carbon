{
  "name": "vsCodeExt",
  "displayName": "EstimatingCarbon",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vsCodeExt.helloWorld",
    "onCommand:vsCodeExt.resetStore",
    "onCommand:vsCodeExt.inputdisplay",
    "onCommand:vsCodeExt.setApiKey",
    "onView:myPrimaryView"
  ],

  
  "main": "./dist/extension.js",
  "contributes": {
        "keybindings": [
      {
        "command": "vsCodeExt.wrappedInline",
        "key": "tab",
        "when": "editorTextFocus && inlineSuggestionVisible && !isSnippetMode"
      },
      {

        "key": "ctrl+i",
        "command": "vsCodeExt.wrappedInlineChat",
        "when": "editorFocus && inlineChatHasEditsAgent && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor != 'workbench.editor.notebook' || editorFocus && inlineChatHasNotebookAgent && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor == 'workbench.editor.notebook' || editorFocus && inlineChatHasNotebookInline && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor == 'workbench.editor.notebook' || editorFocus && inlineChatHasProvider && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor != 'workbench.editor.notebook'"
      }

    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "my-view-container",
          "title": "Estimating Carbon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "my-view-container": [
        {
          "id": "myPrimaryView",
          "name": "Carbon Estimates"
        }
      ]
    },
    "commands": [
      {
        "command": "vsCodeExt.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "vsCodeExt.clearStore",
        "title": "Clear stored calls"
      },
      {
        "command": "vsCodeExt.inputdisplay",
        "title": "Input Display"
      },
      {
        "command": "vsCodeExt.wrappedInline",
        "title": "Inline Commit"
      },
      {
        "command": "vsCodeExt.wrappedInlineChat",
        "title": "Inline chat accepted"
      },
      {
        "command": "vsCodeExt.setApiKey",
        "title": "Set Api Key"
      },
      {
        "command": "interceptor.start",
        "title": "Start Proxy Interceptor",
        "category": "Interceptor"
      },
      {
        "command": "interceptor.stop",
        "title": "Stop Proxy Interceptor",
        "category": "Interceptor"
      },
      {
        "command": "interceptor.openTerminal",
        "title": "Open Runtime Terminal",
        "category": "Interceptor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.16",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.18.11",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "tiktoken": "^1.0.22",
    "http-proxy": "^1.18.1",
    "mockttp": "^4.2.1"
  }
}
